diff --git a/arch/riscv/dts/cv1813h.dtsi b/arch/riscv/dts/cv1813h.dtsi
new file mode 100644
--- /dev/null
+++ b/arch/riscv/dts/cv1813h.dtsi
@@ -0,0 +1,38 @@
+// SPDX-License-Identifier: (GPL-2.0 OR MIT)
+/*
+ * Copyright (C) 2024 Andreas Rehn <rehn.andreas86@gmail.com>
+ *
+ * Sophgo CV1813H / SG2000 SoC
+ * Pin-compatible with CV1800B, shares cv18xx peripheral IP.
+ */
+
+#include "cv18xx.dtsi"
+
+/ {
+	compatible = "sophgo,cv1813h";
+};
+
+&clk {
+	compatible = "sophgo,cv1800-clk";
+};
+
+&plic {
+	compatible = "sophgo,cv1800b-plic", "thead,c900-plic";
+};
+
+&clint {
+	compatible = "sophgo,cv1800b-clint", "thead,c900-clint";
+};
+
+/ {
+	soc {
+		emmc: mmc@4300000 {
+			compatible = "sophgo,cv1800b-dwcmshc";
+			reg = <0x4300000 0x1000>;
+			interrupts = <34 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&clk CLK_AXI4_EMMC>, <&clk CLK_EMMC>;
+			clock-names = "core", "bus";
+			status = "disabled";
+		};
+	};
+};
diff --git a/arch/riscv/dts/cv1813h-milkv-duo-s.dts b/arch/riscv/dts/cv1813h-milkv-duo-s.dts
new file mode 100644
--- /dev/null
+++ b/arch/riscv/dts/cv1813h-milkv-duo-s.dts
@@ -0,0 +1,69 @@
+// SPDX-License-Identifier: (GPL-2.0 OR MIT)
+/*
+ * Copyright (C) 2024 Andreas Rehn <rehn.andreas86@gmail.com>
+ *
+ * Device tree for the Milk-V Duo S (Sophgo SG2000/CV1813H)
+ */
+
+/dts-v1/;
+
+#include "cv1813h.dtsi"
+
+/ {
+	model = "Milk-V Duo S";
+	compatible = "milkv,duo-s", "sophgo,cv1813h";
+
+	aliases {
+		ethernet0 = &ethernet0;
+		serial0 = &uart0;
+		serial1 = &uart1;
+		serial2 = &uart2;
+		serial3 = &uart3;
+		serial4 = &uart4;
+		mmc0 = &sdhci0;
+		mmc1 = &emmc;
+	};
+
+	chosen {
+		stdout-path = "serial0:115200n8";
+	};
+
+	memory@80000000 {
+		device_type = "memory";
+		reg = <0x80000000 0x1fe00000>;
+	};
+};
+
+&ethernet0 {
+	status = "okay";
+	phy-mode = "rmii";
+};
+
+&osc {
+	clock-frequency = <25000000>;
+};
+
+&sdhci0 {
+	status = "okay";
+	bus-width = <4>;
+	no-1-8-v;
+	no-mmc;
+	no-sdio;
+};
+
+&emmc {
+	status = "okay";
+	bus-width = <4>;
+	no-sd;
+	no-sdio;
+	non-removable;
+	disable-wp;
+};
+
+&spif {
+	status = "okay";
+};
+
+&uart0 {
+	status = "okay";
+};
