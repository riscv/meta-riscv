diff --git a/board/sophgo/milkv_duo_s/board.c b/board/sophgo/milkv_duo_s/board.c
new file mode 100644
--- /dev/null
+++ b/board/sophgo/milkv_duo_s/board.c
@@ -0,0 +1,78 @@
+// SPDX-License-Identifier: GPL-2.0+
+/*
+ * Copyright (c) 2024, Andreas Rehn <rehn.andreas86@gmail.com>
+ */
+
+#include <dm/lists.h>
+#include <env.h>
+#include <net.h>
+#include <asm/io.h>
+#include <fdt_support.h>
+
+#include "../milkv_duo/ethernet.h"
+
+#define PINMUX_BASE		0x03001000
+#define EFUSE_SHADOW_BASE	0x03050100
+
+static void cv181x_emmc_pinmux_init(void)
+{
+	/* Configure eMMC pins to function 0 (eMMC mode) */
+	writel(0, (void *)(PINMUX_BASE + 0x48));  /* EMMC_RSTN */
+	writel(0, (void *)(PINMUX_BASE + 0x4c));  /* EMMC_DAT2 */
+	writel(0, (void *)(PINMUX_BASE + 0x50));  /* EMMC_CLK */
+	writel(0, (void *)(PINMUX_BASE + 0x54));  /* EMMC_DAT0 */
+	writel(0, (void *)(PINMUX_BASE + 0x58));  /* EMMC_DAT3 */
+	writel(0, (void *)(PINMUX_BASE + 0x5c));  /* EMMC_CMD */
+	writel(0, (void *)(PINMUX_BASE + 0x60));  /* EMMC_DAT1 */
+}
+
+int misc_init_r(void)
+{
+	u32 ef0, ef1;
+	u8 mac[6];
+
+	/* Skip if ethaddr is already set */
+	if (env_get("ethaddr"))
+		return 0;
+
+	/* Derive MAC from efuse shadow registers (unique per chip) */
+	ef0 = readl((void *)EFUSE_SHADOW_BASE + 0x08);
+	ef1 = readl((void *)EFUSE_SHADOW_BASE + 0x0c);
+
+	if (ef0 == 0 && ef1 == 0)
+		return 0;  /* efuse empty, fall back to random */
+
+	mac[0] = (ef1 >> 8) & 0xff;
+	mac[1] = (ef1 >> 0) & 0xff;
+	mac[2] = (ef0 >> 24) & 0xff;
+	mac[3] = (ef0 >> 16) & 0xff;
+	mac[4] = (ef0 >> 8) & 0xff;
+	mac[5] = (ef0 >> 0) & 0xff;
+
+	/* Set locally administered + unicast bits */
+	mac[0] = (mac[0] & 0xfe) | 0x02;
+
+	eth_env_set_enetaddr("ethaddr", mac);
+
+	return 0;
+}
+
+int board_init(void)
+{
+	if (IS_ENABLED(CONFIG_SYSRESET_CV1800B))
+		device_bind_driver(gd->dm_root, "cv1800b_sysreset", "sysreset", NULL);
+
+	if (IS_ENABLED(CONFIG_NET))
+		cv1800b_ephy_init();
+
+	cv181x_emmc_pinmux_init();
+
+	return 0;
+}
+
+int ft_board_setup(void *blob, struct bd_info *bd)
+{
+	/* Write ethaddr into kernel DTB so Linux gets the same MAC */
+	fdt_fixup_ethernet(blob);
+	return 0;
+}
