From: Pritesh Patel <pritesh.patel@einfochips.com>
Date: Tue, 4 Nov 2025 15:02:00 +0530
Subject: [PATCH 27/36] riscv: dts: eswin: Add emmc Node

Signed-off-by: Pritesh Patel <pritesh.patel@einfochips.com>

Upstream-Status: Pending [https://github.com/hehuaneswincomputing/linux-next/commit/a7ee4d74ab46c5a5a5dff343d1f5416fd57bfa1f]
---
 .../boot/dts/eswin/eic7700-hifive-premier-p550.dts   |  4 ++++
 arch/riscv/boot/dts/eswin/eic7700.dtsi               | 12 ++++++++++++
 2 files changed, 16 insertions(+)

diff --git a/arch/riscv/boot/dts/eswin/eic7700-hifive-premier-p550.dts b/arch/riscv/boot/dts/eswin/eic7700-hifive-premier-p550.dts
index 3e11f1e9583a..7439fc9d9dfe 100644
--- a/arch/riscv/boot/dts/eswin/eic7700-hifive-premier-p550.dts
+++ b/arch/riscv/boot/dts/eswin/eic7700-hifive-premier-p550.dts
@@ -55,3 +55,7 @@ &uart2 {
 &pinctrl {
 	status = "okay";
 };
+
+&sdhci_emmc {
+	status = "okay";
+};
diff --git a/arch/riscv/boot/dts/eswin/eic7700.dtsi b/arch/riscv/boot/dts/eswin/eic7700.dtsi
index 22ad6dabafe1..d3f96c248f3f 100644
--- a/arch/riscv/boot/dts/eswin/eic7700.dtsi
+++ b/arch/riscv/boot/dts/eswin/eic7700.dtsi
@@ -369,5 +369,17 @@ pinctrl: pinctrl@51600080 {
 			vrgmii-supply = <&vcc_1v8>;
 			status = "disabled";
 		};
+
+		sdhci_emmc: mmc@50450000 {
+			compatible = "eswin,eic7700-dwcmshc";
+			reg = <0x0 0x50450000 0x0 0x10000>;
+			interrupts = <79>;
+			clocks = <&clk 190>, <&clk 171>;
+			clock-names = "clk_xin", "clk_ahb";
+			bus-width = <8>;
+			#address-cells = <1>;
+			#size-cells = <0>;
+			status = "disabled";
+		};
 	};
 };
