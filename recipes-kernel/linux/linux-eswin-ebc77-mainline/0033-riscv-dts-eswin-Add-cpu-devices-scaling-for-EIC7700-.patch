diff --git a/arch/riscv/boot/dts/eswin/eic7700.dtsi b/arch/riscv/boot/dts/eswin/eic7700.dtsi
index 5f7d359a8fb8..f7796ab44ba9 100644
--- a/arch/riscv/boot/dts/eswin/eic7700.dtsi
+++ b/arch/riscv/boot/dts/eswin/eic7700.dtsi
@@ -6,6 +6,7 @@
 /dts-v1/;
 
 #include <dt-bindings/riscv/physical-memory.h>
+#include "eic7700-opptable.dtsi"
 
 / {
 	#address-cells = <2>;
@@ -20,6 +21,16 @@ cpus {
 		#size-cells = <0>;
 		timebase-frequency = <1000000>;
 
+		idle-states {
+			CPU_RET: cpu-retentive {
+				compatible = "riscv,idle-state";
+				riscv,sbi-suspend-param = <0x00000000>;
+				entry-latency-us = <20>;
+				exit-latency-us = <40>;
+				min-residency-us = <80>;
+			};
+		};
+
 		cpu0: cpu@0 {
 			compatible = "sifive,p550", "riscv";
 			device_type = "cpu";
@@ -41,6 +52,12 @@ cpu0: cpu@0 {
 					       "zba", "zbb", "zicsr", "zifencei";
 			tlb-split;
 
+			clocks = <&clk EIC7700_CLK_GATE_CPU_EXT_SRC_CORE_CLK_0>;
+			operating-points-v2 = <&cpu_opp_table>;
+			#cooling-cells = <2>;
+			dynamic-power-coefficient = <800>;
+			cpu-idle-states = <&CPU_RET>;
+
 			cpu0_intc: interrupt-controller {
 				compatible = "riscv,cpu-intc";
 				#interrupt-cells = <1>;
@@ -69,6 +86,12 @@ cpu1: cpu@1 {
