 arch/riscv/boot/dts/eswin/eic7700.dtsi        |  35 +++
 2 files changed, 291 insertions(+)
 create mode 100644 arch/riscv/boot/dts/eswin/eic7700-opptable.dtsi

diff --git a/arch/riscv/boot/dts/eswin/eic7700-opptable.dtsi b/arch/riscv/boot/dts/eswin/eic7700-opptable.dtsi
