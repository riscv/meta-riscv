 .../boot/dts/spacemit/k1-bananapi-cm6-io.dts  | 215 +++++++++++++++++
 .../boot/dts/spacemit/k1-bananapi-cm6.dtsi    | 227 ++++++++++++++++++
 3 files changed, 443 insertions(+)
 create mode 100644 arch/riscv/boot/dts/spacemit/k1-bananapi-cm6-io.dts
